CONFIG_TUYA_MODULE_T5=y
# CONFIG_DISABLE_TUYA_OTA_PACK is not set
# CONFIG_ENABLE_AI_MODE_HOLD is not set
# CONFIG_ENABLE_AI_MODE_ONESHOT is not set
# CONFIG_ENABLE_AI_MODE_WAKEUP is not set
CONFIG_ENABLE_AI_MODE_FREE=y
CONFIG_USING_BOARD_AUDIO_INPUT=y
CONFIG_USING_BOARD_AUDIO_OUTPUT=y
CONFIG_T5AI_BOARD=y
CONFIG_SUPERT_USE_EYES_UI=y
# CONFIG_T5AI_BOARD_EYES is not set
# CONFIG_T5AI_BOARD_EVB is not set
# CONFIG_T5AI_BOARD_ROBOT is not set
# CONFIG_T5AI_BOARD_DESKTOP is not set
# CONFIG_WUKONG_BOARD_UBUNTU is not set
# CONFIG_ENABLE_TUYA_CAMERA is not set
# CONFIG_ENABLE_AI_MODE_P2P is not set
CONFIG_ENABLE_TUYA_UI=y
CONFIG_TUYA_CPU_ARCH_SMP=y
CONFIG_TUYA_MULTI_TYPES_LCD=y
# CONFIG_TUYA_APP_DRIVERS_TP is not set
CONFIG_RGB565_COLOR_SWAP_LVGL=y
CONFIG_RGB888_COLOR_SWAP_LVGL=y
CONFIG_TUYA_LVGL_VERSION=8
# CONFIG_TUYA_LINGDONG_GUI is not set
# CONFIG_TUYA_IMG_DIRECT_FLUSH is not set
CONFIG_TUYA_LVGL_DRAW_WITH_ARM2D=y
# CONFIG_TUYA_FILE_SYSTEM is not set
CONFIG_TUYA_LIBJPEG_TURBO=y
CONFIG_TUYA_LIB_FREETYPE=y
CONFIG_TUYA_AI_TOY_DEMO=y
# CONFIG_ENABLE_CELLULAR_DONGLE is not set
CONFIG_TUYA_AI_CHAT_DEFAULT_MODE=3

#
# AI player Decoder Options
#
CONFIG_AI_PLAYER_DECODER_OPUS_ENABLE=y
CONFIG_AI_PLAYER_DECODER_OPUS_FRAME_SIZE=40
CONFIG_AI_PLAYER_DECODER_OPUS_KBPS=16
# end of AI player Decoder Options
